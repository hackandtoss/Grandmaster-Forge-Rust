# Copy this file to .env and fill in your local values.
# Do not commit .env.

# Lichess personal API token. Needs read:games for game sync.
LICHESS_API_KEY=

# Your usernames, used to identify your side in imported games.
LICHESS_USERNAME=
CHESSCOM_USERNAME=

# Chess.com asks API clients to send a contact User-Agent.
# This is not a token. Use an app/contact string like:
# Grandmaster-Forge-Rust/0.1 your-email@example.com
CHESSCOM_USER_AGENT=

# Optional. If empty, the app tries `stockfish` on PATH, then the bundled mock engine.
STOCKFISH_PATH=
